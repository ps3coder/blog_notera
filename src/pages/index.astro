---
/**
 * Blog home — Lists posts from local markdown in src/content/blog/*.md.
 * Auto-detected at build time (no manual registry, no DB).
 */
import Layout from "../layouts/Layout.astro";

type Frontmatter = {
	title?: string;
	description?: string;
	pubDate?: string;
	draft?: boolean;
};

const modules = await Astro.glob<{
	frontmatter: Frontmatter;
	file: string;
}>("../content/blog/*.md");

function slugFromFile(file: string): string {
	return file.split(/[/\\]/).pop()?.replace(/\.md$/i, "") ?? file;
}

const posts: Array<{ slug: string } & Frontmatter> = modules.map((m) => ({
	slug: slugFromFile(m.file),
	...(m.frontmatter ?? {}),
}));

const list = posts
	.filter((p) => !p.draft)
	.sort((a, b) => {
		const da = a.pubDate ? new Date(a.pubDate).getTime() : 0;
		const db = b.pubDate ? new Date(b.pubDate).getTime() : 0;
		return db - da;
	});
---

<Layout>
	<script is:inline>
		(function(){ try { var v = localStorage.getItem('blogViewMode'); document.body.dataset.blogViewMode = (v === 'grid' || v === 'list') ? v : 'list'; } catch(e) { document.body.dataset.blogViewMode = 'list'; } })();
	</script>
	<script
		type="module"
		src={new URL("../scripts/pretext-balance.ts", import.meta.url).toString()}
	></script>
	<main class="blog-page" aria-label="Blog">
		<section class="blog-intro">
			<h1 class="blog-title">Blog</h1>
			<p class="blog-paragraph">
				&nbsp;
			</p>
		</section>

		<section class="blog-list blog-list-list" aria-label="Posts (list)">
			<ul class="post-list">
				{list.map((post) => (
					<li class="post-item">
						<a class="post-link" href={`/blog/${post.slug}`}>
							<span class="post-title">{post.title}</span>
							{post.pubDate && (
								<time class="post-date" datetime={post.pubDate}>
									{new Date(post.pubDate).toLocaleDateString("en-US", {
										year: "numeric",
										month: "short",
										day: "numeric",
									})}
								</time>
							)}
						</a>
						{post.description && (
							<p class="post-description">{post.description}</p>
						)}
					</li>
				))}
			</ul>
			{list.length === 0 && (
				<p class="blog-paragraph">No posts yet. Add markdown files under <code>src/content/blog</code>.</p>
			)}
		</section>

		<section class="blog-list blog-list-grid" aria-label="Posts (grid)">
			{list.length === 0 ? (
				<p class="blog-paragraph">No posts yet. Add markdown files under <code>src/content/blog</code>.</p>
			) : (
				<div class="post-grid">
					{list.map((post) => (
						<a class="post-card" href={`/blog/${post.slug}`}>
							<h2 class="post-card-title">{post.title}</h2>
							{post.pubDate && (
								<time class="post-card-date" datetime={post.pubDate}>
									{new Date(post.pubDate).toLocaleDateString("en-US", {
										year: "numeric",
										month: "short",
										day: "numeric",
									})}
								</time>
							)}
							{post.description && (
								<p class="post-card-description">{post.description}</p>
							)}
						</a>
					))}
				</div>
			)}
		</section>
	</main>
	<script>
		(function () {
			function setViewMode(mode: string) {
				document.body.dataset.blogViewMode = mode;
			}
			try {
				var saved = localStorage.getItem('blogViewMode');
				if (saved === 'grid' || saved === 'list') setViewMode(saved);
			} catch (e) {}
			window.addEventListener('blog-view-change', function (e: Event) {
				var ev = e as CustomEvent<{ view: string }>;
				if (ev.detail && (ev.detail.view === 'grid' || ev.detail.view === 'list')) setViewMode(ev.detail.view);
			});
		})();
	</script>
</Layout>

<style>
	.blog-page {
		max-width: min(1270px, 100%);
		margin: 0 auto;
		padding: 2.78rem clamp(1.25rem, 6vw, 2.78rem) 4rem;
		min-height: 100vh;
		font-family: "PP Neue Montreal", "NeueMontreal-Regular", -apple-system,
			BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
		box-sizing: border-box;
	}

	.blog-intro {
		background: var(--color-bg);
		color: var(--color-ink);
	}

	.blog-title {
		margin: 0 0 1.67rem;
		font-weight: 400;
		font-size: 2.78rem;
		line-height: 3.33rem;
		letter-spacing: 0;
		color: var(--color-ink);
	}

	.blog-paragraph {
		margin: 0 0 1rem;
		max-width: 65ch;
		font-size: 1rem;
		line-height: 1.67rem;
		color: var(--color-ink);
	}

	.blog-list {
		margin-top: 2.5rem;
		padding-top: 1.5rem;
		border-top: 1px solid var(--color-border);
	}

	@keyframes blog-view-in {
		from {
			opacity: 0;
			transform: translateY(6px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.blog-list-grid {
		display: none;
	}

	body[data-blog-view-mode="grid"] .blog-list-list {
		display: none;
	}

	body[data-blog-view-mode="grid"] .blog-list-grid {
		display: block;
		animation: blog-view-in 0.28s ease-out;
	}

	body[data-blog-view-mode="list"] .blog-list-list {
		animation: blog-view-in 0.28s ease-out;
	}

	.post-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 1.5rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.post-card {
		display: block;
		padding: 0;
		background: none;
		text-decoration: none;
		color: inherit;
	}

	.post-card-title {
		margin: 0 0 0.5rem;
		font-size: 1.22rem;
		line-height: 1.4;
		font-weight: 400;
		color: var(--color-link);
		text-decoration: none;
		transition: color 0.15s ease;
	}

	.post-card:hover .post-card-title,
	.post-card:focus-visible .post-card-title {
		color: var(--color-link-hover);
	}

	.post-card-date {
		display: block;
		font-size: 0.9rem;
		color: var(--color-muted);
		margin-bottom: 0.35rem;
	}

	.post-card-description {
		margin: 0;
		font-size: 0.95rem;
		line-height: 1.5;
		color: var(--color-muted);
	}

	.post-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.post-item {
		margin-bottom: 1.5rem;
	}

	.post-link {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 0.75rem;
		text-decoration: none;
		color: var(--color-link);
	}

	.post-link:hover,
	.post-link:focus-visible {
		color: var(--color-link-hover);
	}

	.post-title {
		font-size: 1.22rem;
		line-height: 1.4;
		font-weight: 400;
	}

	.post-date {
		font-size: 0.9rem;
		color: var(--color-muted);
	}

	.post-description {
		margin: 0.35rem 0 0;
		max-width: 65ch;
		font-size: 0.95rem;
		line-height: 1.5;
		color: var(--color-muted);
	}

	code {
		font-size: 0.9em;
		padding: 0.15em 0.4em;
		background: var(--color-border);
		border-radius: 4px;
	}

	@media screen and (max-width: 768px) {
		.blog-page {
			padding: 2rem clamp(1rem, 4vw, 1.5rem) 3rem;
		}

		.blog-title {
			font-size: 2.22rem;
			line-height: 2.78rem;
		}
	}
</style>
