---
/**
 * Single post — Content rendered from local markdown in src/content/blog/*.md.
 * Auto-generated routes at build time (no registry, no DB).
 */
import Layout from "../../layouts/Layout.astro";

type Frontmatter = {
	title?: string;
	description?: string;
	pubDate?: string;
	draft?: boolean;
};

export async function getStaticPaths() {
	const modules = (await Astro.glob("../../content/blog/*.md")) as Array<{
		frontmatter: Frontmatter;
		file: string;
		Content: any;
	}>;

	return modules
		.filter((m) => !m.frontmatter?.draft)
		.map((m) => {
			const slug = m.file.split(/[/\\]/).pop()?.replace(/\.md$/i, "") ?? m.file;
			return {
				params: { slug },
			props: {
				slug,
				frontmatter: m.frontmatter,
				Content: m.Content,
			},
			};
		});
}

const { frontmatter, Content } = Astro.props;
const { title, description, pubDate } = frontmatter as Frontmatter;
---

<Layout themeControlVariant="post">
	<div class="back-to-blog-wrap">
		<a href="/" class="theme-slider-box back-to-blog-btn" aria-label="Back to blog">
			<svg class="icon-view icon-back-up" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<path d="m9 14l-4-4l4-4"/>
				<path d="M5 10h11a4 4 0 1 1 0 8h-1"/>
			</svg>
		</a>
	</div>
	<main class="blog-page post-page" aria-label="Blog post">
		<article class="post-article">
			<header class="post-header">
				<h1 class="post-title">{title}</h1>
				{pubDate && (
					<time class="post-date" datetime={pubDate}>
						{new Date(pubDate).toLocaleDateString("en-US", {
							year: "numeric",
							month: "long",
							day: "numeric",
						})}
					</time>
				)}
				{description && (
					<p class="post-description">{description}</p>
				)}
			</header>
			<div class="post-content set-prose">
				<Content />
			</div>
		</article>
	</main>
</Layout>

<style>
	.blog-page {
		max-width: min(1270px, 100%);
		margin: 0 auto;
		padding: 2.78rem clamp(1rem, 5vw, 2.78rem) 4rem;
		min-height: 100vh;
		font-family: "PP Neue Montreal", "NeueMontreal-Regular", -apple-system,
			BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
		box-sizing: border-box;
	}

	.post-page {
		padding-top: 5.5rem;
		padding-left: clamp(1.25rem, 6vw, 2.78rem);
		padding-right: clamp(1.25rem, 6vw, 2.78rem);
	}

	.post-header {
		margin-bottom: 2rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--color-border);
	}

	.post-title {
		margin: 0 0 0.5rem;
		font-weight: 400;
		font-size: 2.22rem;
		line-height: 2.78rem;
		letter-spacing: 0;
		color: var(--color-ink);
	}

	.post-date {
		display: block;
		font-size: 0.95rem;
		color: var(--color-muted);
		margin-bottom: 0.75rem;
	}

	.post-description {
		margin: 0;
		max-width: 65ch;
		font-size: 1rem;
		line-height: 1.6;
		color: var(--color-muted);
	}

	/* Prose: same typography as AboutMe for markdown content */
	.post-content.set-prose {
		color: var(--color-ink);
		font-size: 1rem;
		line-height: 1.67rem;
		max-width: 65ch;
	}

	.post-content.set-prose :global(h1) {
		font-size: 1.67rem;
		line-height: 2rem;
		margin: 2rem 0 1rem;
		font-weight: 400;
		color: var(--color-ink);
	}

	.post-content.set-prose :global(h2) {
		font-size: 1.33rem;
		line-height: 1.5;
		margin: 1.75rem 0 0.75rem;
		font-weight: 400;
		color: var(--color-ink);
	}

	.post-content.set-prose :global(h3) {
		font-size: 1.15rem;
		margin: 1.25rem 0 0.5rem;
		font-weight: 400;
		color: var(--color-ink);
	}

	.post-content.set-prose :global(p) {
		margin: 0 0 1rem;
		color: var(--color-ink);
	}

	.post-content.set-prose :global(ul),
	.post-content.set-prose :global(ol) {
		margin: 0 0 1rem;
		padding-left: 1.5rem;
		color: var(--color-ink);
	}

	.post-content.set-prose :global(li) {
		margin-bottom: 0.35rem;
	}

	.post-content.set-prose :global(blockquote) {
		margin: 1rem 0;
		padding-left: 1rem;
		border-left: 3px solid var(--color-border);
		color: var(--color-muted);
		font-style: italic;
	}

	.post-content.set-prose :global(a) {
		color: var(--color-link);
		text-decoration: underline;
	}

	.post-content.set-prose :global(a:hover),
	.post-content.set-prose :global(a:focus-visible) {
		color: var(--color-link-hover);
	}

	.post-content.set-prose :global(pre) {
		overflow-x: auto;
		padding: 1rem;
		background: var(--color-paper);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		font-size: 0.9rem;
		line-height: 1.5;
		margin: 1rem 0;
	}

	.post-content.set-prose :global(code) {
		font-size: 0.9em;
		padding: 0.15em 0.4em;
		background: var(--color-border);
		border-radius: 4px;
	}

	.post-content.set-prose :global(pre code) {
		padding: 0;
		background: none;
	}

	.post-content.set-prose :global(table) {
		width: 100%;
		border-collapse: collapse;
		margin: 1rem 0;
		font-size: 0.95rem;
	}

	.post-content.set-prose :global(th),
	.post-content.set-prose :global(td) {
		padding: 0.5rem 0.75rem;
		text-align: left;
		border-bottom: 1px solid var(--color-border);
		color: var(--color-ink);
	}

	.post-content.set-prose :global(hr) {
		border: none;
		border-top: 1px solid var(--color-border);
		margin: 1.5rem 0;
	}

	.post-content.set-prose :global(img) {
		max-width: 100%;
		height: auto;
	}

	.post-content.set-prose :global(pre),
	.post-content.set-prose :global(table) {
		max-width: 100%;
	}

	@media screen and (max-width: 768px) {
		.blog-page {
			padding: 2rem clamp(1rem, 4vw, 1.5rem) 3rem;
		}

		.post-page {
			padding-top: 9rem;
			padding-left: clamp(1rem, 4vw, 1.5rem);
			padding-right: clamp(1rem, 4vw, 1.5rem);
		}

		.post-title {
			font-size: 1.78rem;
			line-height: 2.22rem;
		}
	}
</style>
